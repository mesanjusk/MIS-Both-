PORT=5000
MONGO_URI=mongodb://127.0.0.1:27017/mis
ACCESS_TOKEN_SECRET=replace_with_jwt_secret

# Meta / WhatsApp Cloud
META_APP_ID=your_meta_app_id
META_APP_SECRET=your_meta_app_secret
META_API_VERSION=v18.0
WHATSAPP_WEBHOOK_VERIFY_TOKEN=your_random_webhook_verify_token
WHATSAPP_ENFORCE_WEBHOOK_SIGNATURE=true
WHATSAPP_TOKEN_ENCRYPTION_KEY=base64_encoded_32_byte_key

OWNER_WHATSAPP_NUMBER=91XXXXXXXXXX

# Google OAuth (shared for Drive + Gmail — same Google Cloud project credentials)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=https://misbackend-e078.onrender.com/api/google-drive/callback

# Gmail Multi-Account Integration
# Add GMAIL_REDIRECT_URI in Google Cloud Console → Credentials → OAuth 2.0 → Authorized redirect URIs
GMAIL_REDIRECT_URI=https://misbackend-e078.onrender.com/api/gmail/callback
# Optional: Google Drive folder ID where large files (>24MB) are uploaded before emailing a link
GMAIL_DRIVE_FOLDER_ID=

# Frontend URL (used to redirect browser back after Gmail OAuth connect)
FRONTEND_URL=https://dash.sanjusk.in

# Allowed CORS origins (comma-separated)
ALLOWED_ORIGINS=https://dash.sanjusk.in

# Internal cron key
INTERNAL_API_KEY=replace_with_random_secret
